{
  "name": "dream-transmission",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-manifest": "if [ -d \"public/music\" ]; then bun scripts/generate-manifest.js; else echo \"Skipping manifest generation: public/music not found\"; fi",
    "predev": "bun run generate-manifest",
    "prebuild": "bun run generate-manifest",
    "dev": "vite",
    "build": "vite build",
    "build:worker": "vite build",
    "deploy": "wrangler deploy",
    "preview": "vite preview",
    "lint": "oxlint",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "lint:fix": "oxlint --fix . && oxfmt"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "animejs": "^4.3.6",
    "framer-motion": "^12.35.2",
    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "postprocessing": "^6.38.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.72.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
